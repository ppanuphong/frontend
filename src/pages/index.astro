---
import { NmrDashboard } from "../components/dashboard/NmrDashboard";
import "../styles/globals.css";
---
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NMR Spectroscopy Suite — AI Metabolomics Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js" is:inline></script>
</head>
<body>
    <NmrDashboard />

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            let DEMO = null;

            const PLOT_BG = 'rgba(0,0,0,0)';
            const GRID = 'rgba(15,23,42,0.07)';
            const TICK = '#64748B';
            const baseLayout = (extra = {}) => ({
                plot_bgcolor: PLOT_BG,
                paper_bgcolor: PLOT_BG,
                font: { family: 'Inter, sans-serif', color: '#475569', size: 11 },
                xaxis: { gridcolor: GRID, tickfont: { color: TICK }, zerolinecolor: GRID, ...extra.xaxis },
                yaxis: { gridcolor: GRID, tickfont: { color: TICK }, zerolinecolor: GRID, ...extra.yaxis },
                margin: { l: 44, r: 16, t: 10, b: 40 },
                legend: { font: { size: 10, color: '#475569' }, bgcolor: 'rgba(255,255,255,0.6)', x: 0.02, y: 0.98 },
                ...extra
            });

            const sampleSelect = document.getElementById('sample-select');
            const noiseSlider = document.getElementById('noise-slider');
            const noiseVal = document.getElementById('noise-val');
            const driftSlider = document.getElementById('drift-slider');
            const driftVal = document.getElementById('drift-val');
            const ghostCheckbox = document.getElementById('ghost-checkbox');
            const ebmSlider = document.getElementById('ebm-slider');
            const ebmVal = document.getElementById('ebm-val');
            const fileUpload = document.getElementById('file-upload');
            const analyzeBtn = document.getElementById('analyze-btn');
            const btnText = analyzeBtn.querySelector('.btn-text');
            const btnLoader = analyzeBtn.querySelector('.btn-loader');
            const scorecardExtract = document.getElementById('scorecard-extract');
            const scorecardStatus = document.getElementById('scorecard-status');
            const scorecardQc = document.getElementById('scorecard-qc');
            const alertBanner = document.getElementById('alert-banner');
            const alertBadge = document.getElementById('alert-badge');
            const alertTitle = document.getElementById('alert-title');
            const alertDesc = document.getElementById('alert-desc');
            const tbody = document.getElementById('biomarker-tbody');
            const accordionToggle = document.getElementById('accordion-toggle');
            const accordionPanel = document.getElementById('accordion-panel');
            const gaugeCircle = document.getElementById('gauge-circle');
            const gaugeVal = document.getElementById('gauge-val');
            const gaugeLbl = document.getElementById('gauge-lbl');
            const jsonPayload = document.getElementById('json-payload');
            const downloadJsonBtn = document.getElementById('download-json-btn');

            function interpolate(x, y, targetX) {
                return targetX.map(tx => {
                    if (tx <= x[0]) return y[0];
                    if (tx >= x[x.length - 1]) return y[y.length - 1];
                    let i = 0;
                    while (i < x.length - 1 && x[i + 1] < tx) i++;
                    const t = (tx - x[i]) / (x[i + 1] - x[i]);
                    return y[i] + t * (y[i + 1] - y[i]);
                });
            }

            function downsample(x, y, target = 2000) {
                const factor = Math.floor(x.length / target);
                if (factor <= 1) return { x, y };
                const xs = [], ys = [];
                for (let i = 0; i < target; i++) {
                    const idx = i * factor;
                    xs.push(x[idx]);
                    let mx = -Infinity;
                    for (let j = 0; j < factor; j++) if (y[idx + j] > mx) mx = y[idx + j];
                    ys.push(mx);
                }
                return { x: xs, y: ys };
            }

            function buildZoomPeakLabelLayout(annotations, zMin, zMax, maxSignal) {
                const peakMap = {};
                annotations.forEach(annotation => {
                    if (annotation.ppm_position < zMin || annotation.ppm_position > zMax) return;
                    const current = peakMap[annotation.compound_name];
                    if (!current || annotation.relative_intensity > current.relative_intensity) {
                        peakMap[annotation.compound_name] = annotation;
                    }
                });

                const limit = window.innerWidth < 768 ? 4 : 6;
                const visiblePeaks = Object.values(peakMap)
                    .sort((a, b) => b.relative_intensity - a.relative_intensity)
                    .slice(0, limit)
                    .sort((a, b) => a.ppm_position - b.ppm_position);

                const safeSignalMax = Math.max(maxSignal || 0, 1);
                const tierStep = safeSignalMax * 0.14;
                const labelBase = safeSignalMax * 1.1;
                const tierThreshold = (zMax - zMin) * (window.innerWidth < 768 ? 0.14 : 0.09);
                const markerTrace = {
                    x: [],
                    y: [],
                    mode: 'markers',
                    marker: { color: '#F59E0B', size: 7, symbol: 'diamond' },
                    hoverinfo: 'skip',
                    showlegend: false
                };
                const shapes = [];
                const plotAnnotations = [];
                let previousPeak = null;

                visiblePeaks.forEach(peak => {
                    let tier = 0;
                    if (previousPeak && Math.abs(peak.ppm_position - previousPeak.ppm_position) < tierThreshold) {
                        tier = (previousPeak._tier + 1) % 3;
                    }
                    peak._tier = tier;
                    previousPeak = peak;

                    const stemTop = labelBase + tier * tierStep;
                    markerTrace.x.push(peak.ppm_position);
                    markerTrace.y.push(peak.relative_intensity);
                    shapes.push({
                        type: 'line',
                        x0: peak.ppm_position,
                        x1: peak.ppm_position,
                        y0: peak.relative_intensity,
                        y1: stemTop,
                        line: { color: 'rgba(245, 158, 11, 0.85)', width: 1.2 }
                    });
                    plotAnnotations.push({
                        x: peak.ppm_position,
                        y: stemTop,
                        text: peak.compound_name,
                        showarrow: false,
                        xanchor: 'center',
                        yanchor: 'bottom',
                        font: {
                            family: 'JetBrains Mono, monospace',
                            size: window.innerWidth < 768 ? 9 : 10,
                            color: '#0F172A'
                        },
                        bgcolor: 'rgba(255,255,255,0.96)',
                        bordercolor: 'rgba(245, 158, 11, 0.7)',
                        borderwidth: 1,
                        borderpad: 4
                    });
                });

                const yUpper = visiblePeaks.length ? labelBase + tierStep * 2.6 : safeSignalMax * 1.18;
                return { markerTrace, shapes, plotAnnotations, yUpper };
            }

            async function handleFileUpload(file) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = e => {
                        try {
                            const lines = e.target.result.split('\n');
                            if (lines.length < 10) throw new Error("File too short.");
                            const s = lines[0];
                            let delim = s.includes('\t') ? '\t' : s.includes(';') ? ';' : ',';
                            const data = [];
                            const hasHeader = isNaN(parseFloat(s.split(delim)[0]));
                            for (let i = hasHeader ? 1 : 0; i < lines.length; i++) {
                                const p = lines[i].trim().split(delim);
                                if (p.length >= 2) {
                                    const ppm = parseFloat(p[0]), int = parseFloat(p[1]);
                                    if (!isNaN(ppm) && !isNaN(int)) data.push({ ppm, int });
                                }
                            }
                            if (data.length < 10) throw new Error("No valid (ppm, intensity) pairs found.");
                            data.sort((a, b) => a.ppm - b.ppm);
                            const rx = data.map(d => d.ppm), ry = data.map(d => d.int);
                            const tx = Array.from({ length: 4000 }, (_, i) => 10 * i / 3999);
                            let ty = interpolate(rx, ry, tx);
                            const mx = Math.max(...ty);
                            if (mx > 0) ty = ty.map(v => v / mx * 3.5);
                            resolve({ ppm_axis: tx, raw_spectrum: ty, drifted_ppm: tx, annotations: [], sample_type: "Uploaded_NMR" });
                        } catch (err) { reject(err); }
                    };
                    reader.onerror = () => reject(new Error("File read error."));
                    reader.readAsText(file);
                });
            }

            let activeData = null, currentPayload = null;

            noiseSlider.addEventListener('input', e => {
                noiseVal.textContent = parseFloat(e.target.value).toFixed(3);
            });
            driftSlider.addEventListener('input', e => {
                const v = parseFloat(e.target.value);
                driftVal.textContent = v >= 0 ? `+${v.toFixed(3)}` : v.toFixed(3);
            });
            ghostCheckbox.addEventListener('change', loadActiveSample);
            ebmSlider.addEventListener('input', e => {
                ebmVal.textContent = parseFloat(e.target.value).toFixed(1);
            });
            sampleSelect.addEventListener('change', () => {
                const map = { Plant_Extract_A: "Sugarcane Extract", Plant_Extract_B: "Coffee Extract", Plant_Extract_C: "Soybean Extract" };
                scorecardExtract.textContent = map[sampleSelect.value];
                loadActiveSample();
            });
            accordionToggle.addEventListener('click', () => {
                accordionToggle.classList.toggle('open');
                accordionPanel.classList.toggle('hidden');
            });

            function loadActiveSample() {
                if (!DEMO) return;
                const entry = DEMO[sampleSelect.value];
                if (!entry) return;
                const variant = ghostCheckbox.checked ? entry.ghost : entry.clean;
                activeData = {
                    sample_type: sampleSelect.value,
                    ppm_axis: variant.ppm_axis,
                    raw_spectrum: variant.raw_spectrum,
                    drifted_ppm: variant.ppm_axis,
                    annotations: entry.annotations
                };
                renderPlots();
                renderBiomarkers();
            }

            function renderPlots() {
                if (!activeData) return;
                const { ppm_axis, raw_spectrum, drifted_ppm, annotations, sample_type } = activeData;
                const dsRaw = downsample(drifted_ppm, raw_spectrum);
                const dsAlg = downsample(ppm_axis, raw_spectrum);

                const peakMap = {};
                annotations.forEach(a => {
                    if (!peakMap[a.compound_name] || a.relative_intensity > peakMap[a.compound_name].i) {
                        peakMap[a.compound_name] = { ppm: a.ppm_position, i: a.relative_intensity };
                    }
                });

                Plotly.newPlot('plotly-overlay', [
                    { x: dsRaw.x, y: dsRaw.y, mode: 'lines', line: { color: 'rgba(239,68,68,0.55)', width: 1.5 }, name: 'Raw (Drifted)' },
                    { x: dsAlg.x, y: dsAlg.y, mode: 'lines', line: { color: '#10B981', width: 2 }, name: 'Aligned' },
                    {
                        x: Object.values(peakMap).map(p => p.ppm),
                        y: Object.values(peakMap).map(p => p.i),
                        mode: 'markers',
                        customdata: Object.entries(peakMap).map(([name, peak]) => [name, peak.ppm, peak.i]),
                        hovertemplate: '<b>%{customdata[0]}</b><br>ppm: %{customdata[1]:.2f}<br>Rel. intensity: %{customdata[2]:.2f}<extra></extra>',
                        marker: { color: '#F59E0B', size: 8, symbol: 'triangle-up' },
                        name: 'Biomarkers'
                    }
                ], baseLayout({ height: 260, xaxis: { title: 'Chemical Shift (ppm)', autorange: 'reversed' }, yaxis: { title: 'Intensity' } }));

                const zoomRanges = {
                    Plant_Extract_A: [3.2, 4.5, 'Sugar Region (3.2–4.5 ppm)'],
                    Plant_Extract_B: [6.0, 8.0, 'Aromatic Region (6.0–8.0 ppm)'],
                    Plant_Extract_C: [0.8, 2.8, 'Aliphatic Region (0.8–2.8 ppm)']
                };
                const [zMin, zMax, zLabel] = zoomRanges[sample_type] || zoomRanges.Plant_Extract_A;
                document.getElementById('zoom-region-label').textContent = `Peak Label View — ${zLabel}`;

                const zx = [], zy = [];
                for (let i = 0; i < drifted_ppm.length; i++) {
                    if (drifted_ppm[i] >= zMin && drifted_ppm[i] <= zMax) {
                        zx.push(drifted_ppm[i]);
                        zy.push(raw_spectrum[i]);
                    }
                }
                const dsZ = downsample(zx, zy, 1000);
                const zoomSignalMax = zy.length ? Math.max(...zy) : 1;
                const zoomLabels = buildZoomPeakLabelLayout(annotations, zMin, zMax, zoomSignalMax);

                Plotly.newPlot('plotly-zoom', [
                    { x: dsZ.x, y: dsZ.y, mode: 'lines', line: { color: '#0284C7', width: 2 }, name: 'Zoom' },
                    zoomLabels.markerTrace
                ], baseLayout({
                    height: window.innerWidth < 768 ? 170 : 190,
                    xaxis: { range: [zMax, zMin] },
                    yaxis: { showticklabels: false, range: [0, zoomLabels.yUpper] },
                    showlegend: false,
                    margin: { l: 30, r: 14, t: 36, b: 28 },
                    shapes: zoomLabels.shapes,
                    annotations: zoomLabels.plotAnnotations
                }));

                renderWaterfall();
            }

            function renderWaterfall() {
                try {
                    if (!DEMO) return;
                    const dA = DEMO.Plant_Extract_A.clean;
                    const dB = DEMO.Plant_Extract_B.clean;
                    const dC = DEMO.Plant_Extract_C.clean;
                    const off = 1.3;
                    const dsA = downsample(dA.ppm_axis, dA.raw_spectrum);
                    const dsB = downsample(dB.ppm_axis, dB.raw_spectrum);
                    const dsC = downsample(dC.ppm_axis, dC.raw_spectrum);
                    Plotly.newPlot('plotly-waterfall', [
                        { x: dsC.x, y: dsC.y.map(v => v + 2 * off), mode: 'lines', line: { color: '#8B5CF6', width: 1.5 }, name: 'Soybean (Amino-Rich)' },
                        { x: dsB.x, y: dsB.y.map(v => v + off), mode: 'lines', line: { color: '#EC4899', width: 1.5 }, name: 'Coffee (Aromatic-Rich)' },
                        { x: dsA.x, y: dsA.y, mode: 'lines', line: { color: '#10B981', width: 1.5 }, name: 'Sugarcane (Sugar-Rich)' }
                    ], baseLayout({ height: 460, xaxis: { title: 'Chemical Shift (ppm)', autorange: 'reversed' }, yaxis: { title: 'Intensity (Stacked)', showticklabels: false } }));
                } catch (e) {
                    console.error("Waterfall error:", e);
                }
            }

            function renderBiomarkers() {
                if (!activeData) return;
                const formulas = { Sucrose:"C12H22O11",Glucose:"C6H12O6",Fructose:"C6H12O6",Maltose:"C12H22O11",Xylose:"C5H10O5",Valine:"C5H11NO2",Leucine:"C6H13NO2",Isoleucine:"C6H13NO2",Alanine:"C3H7NO2",Threonine:"C4H9NO3",Citrate:"C6H8O7",Succinate:"C4H6O4",Glutamate:"C5H9NO4",Acetate:"C2H4O2",Formate:"CH2O2",Propionate:"C3H6O2",Chlorogenate:"C16H18O9",Tyrosine:"C9H11NO3",Phenylalanine:"C9H11NO2",Tryptophan:"C11H12N2O2",Histidine:"C6H9N3O2",Methanol:"CH4O",Ethanol:"C2H6O",Choline:"C5H13NO","O-Phosphocholine":"C5H13NO4P","4-Aminobutyrate":"C4H9NO2",Uridine:"C9H12N2O6",Nicotinate:"C6H5NO2" };
                const hmdbIds = { Sucrose:"HMDB0000258",Glucose:"HMDB0000122",Fructose:"HMDB0000660",Maltose:"HMDB0000163",Xylose:"HMDB0000098",Valine:"HMDB0000883",Leucine:"HMDB0000687",Isoleucine:"HMDB0000172",Alanine:"HMDB0000161",Threonine:"HMDB0000167",Citrate:"HMDB0000094",Succinate:"HMDB0000254",Glutamate:"HMDB0000148",Acetate:"HMDB0000042",Formate:"HMDB0000142",Propionate:"HMDB0000237",Chlorogenate:"HMDB0003164",Tyrosine:"HMDB0000158",Phenylalanine:"HMDB0000159",Tryptophan:"HMDB0000929",Histidine:"HMDB0000177",Methanol:"HMDB0001875",Ethanol:"HMDB0000108",Choline:"HMDB0000097","O-Phosphocholine":"HMDB0001565","4-Aminobutyrate":"HMDB0000112",Uridine:"HMDB0000296",Nicotinate:"HMDB0001488" };

                const group = {};
                activeData.annotations.forEach(a => {
                    if (!group[a.compound_name] || a.relative_intensity > group[a.compound_name].relative_intensity) group[a.compound_name] = a;
                });

                tbody.innerHTML = '';
                Object.keys(group).forEach(name => {
                    const weight = group[name].relative_intensity;
                    const pct = Math.min(Math.floor((weight / 2) * 100), 100);
                    const color = pct > 75 ? '#10B981' : pct < 30 ? '#F59E0B' : '#00D4FF';
                    const dbId = hmdbIds[name] || 'HMDB0000000';
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td style="font-weight:700;color:#0F172A;font-family:var(--font-mono);">${name}</td>
                        <td style="font-family:var(--font-mono);color:#64748B;">${formulas[name] || 'N/A'}</td>
                        <td><a href="https://hmdb.ca/metabolites/${dbId}" target="_blank">${dbId}</a></td>
                        <td style="font-weight:700;color:#059669;font-family:var(--font-mono);">95%</td>
                        <td>
                            <div class="progress-wrap">
                                <div class="progress-track">
                                    <div class="progress-fill" style="background:${color};width:${pct}%;"></div>
                                </div>
                                <span class="progress-num">${weight.toFixed(1)}</span>
                            </div>
                        </td>`;
                    tbody.appendChild(tr);
                });
            }

            function mockAnalysis() {
                const ebmThreshold = parseFloat(ebmSlider.value);
                const isGhost = ghostCheckbox.checked;
                const rawEnergy = isGhost ? +(ebmThreshold + 0.4).toFixed(4) : 0.32;
                const seed = sampleSelect.value.charCodeAt(13) || 65;
                const latent_features = Array.from({ length: 128 }, (_, i) => +(0.5 + 0.45 * Math.sin((i + seed) * 0.4) * Math.cos(i * 0.13)).toFixed(4));
                const STEPS = 12;
                const trajectory_steps = Array.from({ length: STEPS }, (_, s) =>
                    Array.from({ length: 128 }, (_, d) =>
                        +(latent_features[d] * (1 - s / STEPS) + 0.5 * (s / STEPS) + 0.05 * Math.sin(s * 0.6 + d)).toFixed(4))
                );
                const telemetry = {
                    pipeline: "3-Stage Hybrid (Transformer → Neural ODE → EBM)",
                    timestamp: new Date().toISOString(),
                    diagnostic_reports: [{
                        sample_id: "NMR-SAMPLE-2026-X99",
                        extract_class: sampleSelect.value,
                        raw_energy_score: rawEnergy,
                        ebm_threshold: ebmThreshold,
                        ghost_peak_detected: isGhost,
                        ebm_validation: isGhost ? "ANOMALY_CLEARED" : "PASSED",
                        biomarkers_identified: (DEMO?.[sampleSelect.value]?.annotations?.length) || 0
                    }]
                };
                return { telemetry, latent_features, trajectory_steps, diagnostics: { ghost_peak_detected: isGhost, raw_energy_score: rawEnergy } };
            }

            analyzeBtn.addEventListener('click', () => {
                if (!activeData) return;
                btnText.textContent = "Processing...";
                btnLoader.classList.remove('hidden');
                analyzeBtn.disabled = true;
                setTimeout(() => {
                    try {
                        const result = mockAnalysis();
                        currentPayload = result.telemetry;
                        renderTechMetrics(result);
                        scorecardStatus.textContent = "COMPLETED";
                        if (result.diagnostics.ghost_peak_detected) {
                            scorecardQc.textContent = "ANOMALY";
                            alertBanner.className = "alert-strip amber";
                            alertBadge.textContent = "ANOMALY DETECTED";
                            alertTitle.textContent = "Ghost Peak Suppressed via EBM Physics Constraint";
                            alertDesc.textContent = "Anomalous contaminant peak detected at 4.15 ppm. Violates spin-spin coupling ratios. Successfully suppressed. Match confidence adjusted.";
                        } else {
                            scorecardQc.textContent = "PASSED";
                            alertBanner.className = "alert-strip emerald";
                            alertBadge.textContent = "PHYSICS PASSED";
                            alertTitle.textContent = "Metabolite Fingerprint Consistent";
                            alertDesc.textContent = "NMR fingerprint satisfies all physics-chemical constraints. Aligned via Latent Neural ODE Solver. No anomalies identified.";
                        }
                        alertBanner.classList.remove('hidden');
                    } catch (e) {
                        console.error("Analyze error:", e);
                    } finally {
                        btnText.textContent = "Run AI Diagnostic";
                        btnLoader.classList.add('hidden');
                        analyzeBtn.disabled = false;
                    }
                }, 600);
            });

            function renderTechMetrics(result) {
                const { latent_features, trajectory_steps, diagnostics } = result;
                Plotly.newPlot('plotly-latent',
                    [{ y: latent_features.slice(0, 64), type: 'bar', marker: { color: '#10B981', opacity: 0.8 } }],
                    baseLayout({ height: 200, xaxis: { title: 'Latent Dim' }, yaxis: { title: 'Activation' }, showlegend: false }));

                const colors = ['#0284C7', '#7C3AED', '#DB2777', '#059669'];
                const dims = [4, 18, 42, 88];
                const steps = trajectory_steps.length;
                Plotly.newPlot('plotly-ode',
                    dims.map((dim, idx) => ({
                        x: Array.from({ length: steps }, (_, i) => i),
                        y: trajectory_steps.map(s => s[dim]),
                        mode: 'lines+markers',
                        line: { color: colors[idx], width: 2 },
                        marker: { size: 5 },
                        name: `Dim ${dim}`
                    })),
                    baseLayout({ height: 200, xaxis: { title: 'ODE Steps' }, yaxis: { title: 'State' } }));

                const energy = diagnostics.raw_energy_score;
                gaugeVal.textContent = energy.toFixed(4);
                const violated = energy > parseFloat(ebmSlider.value);
                gaugeCircle.className = "gauge-ring " + (violated ? "violated" : "stable");
                gaugeLbl.textContent = violated ? "ANOMALY" : "STABLE";
                jsonPayload.textContent = JSON.stringify(result.telemetry, null, 2);

                const models = ['PLS-DA', 'SVM (RBF)', '1D-CNN', 'Transformer', 'NeuralODE+EBM'];
                const baseAcc = [86.4, 89.1, 92.7, 95.3, 98.6];
                const acc = baseAcc.map((v, i) => violated && i < 4 ? +(v - 3.2).toFixed(1) : v);
                const barColors = models.map((_, i) => i === models.length - 1 ? '#0284C7' : '#94A3B8');
                Plotly.newPlot('plotly-accuracy',
                    [{
                        x: acc, y: models, type: 'bar', orientation: 'h',
                        marker: { color: barColors },
                        text: acc.map(v => v.toFixed(1) + '%'),
                        textposition: 'auto',
                        textfont: { family: 'JetBrains Mono, monospace', size: 11 },
                        hovertemplate: '%{y}: %{x:.1f}%<extra></extra>'
                    }],
                    baseLayout({
                        height: 240, showlegend: false,
                        margin: { l: 110, r: 24, t: 8, b: 36 },
                        xaxis: { title: 'Validation Accuracy (%)', range: [80, 100] },
                        yaxis: { automargin: true }
                    }));
            }

            fileUpload.addEventListener('change', async e => {
                const file = e.target.files?.[0];
                if (!file) return;
                btnText.textContent = "Importing...";
                analyzeBtn.disabled = true;
                try {
                    activeData = await handleFileUpload(file);
                    if (DEMO) {
                        const up = activeData.raw_spectrum;
                        const dA = DEMO.Plant_Extract_A.clean, dB = DEMO.Plant_Extract_B.clean, dC = DEMO.Plant_Extract_C.clean;
                        const corr = ref => {
                            const a = up, b = ref.raw_spectrum;
                            const n = Math.min(a.length, b.length);
                            let ma = 0, mb = 0;
                            for (let i = 0; i < n; i++) { ma += a[i]; mb += b[i]; }
                            ma /= n; mb /= n;
                            let num = 0, da = 0, db = 0;
                            for (let i = 0; i < n; i++) {
                                const xa = a[i] - ma, xb = b[i] - mb;
                                num += xa * xb; da += xa * xa; db += xb * xb;
                            }
                            return num / Math.sqrt(da * db + 1e-12);
                        };
                        const cA = corr(dA), cB = corr(dB), cC = corr(dC);
                        const best = [[cA, 'Plant_Extract_A', 'Sugarcane'], [cB, 'Plant_Extract_B', 'Coffee'], [cC, 'Plant_Extract_C', 'Soybean']].sort((a, b) => b[0] - a[0])[0];
                        activeData.sample_type = best[1];
                        activeData.annotations = DEMO[best[1]].annotations;
                        scorecardExtract.textContent = `${best[2]} Extract`;
                        alertBanner.className = "alert-strip emerald";
                        alertBadge.textContent = "FILE MATCHED";
                        alertTitle.textContent = `${file.name} — parsed successfully`;
                        alertDesc.textContent = `Matched to ${best[2]} reference profile via Pearson correlation (${best[0].toFixed(3)}).`;
                        alertBanner.classList.remove('hidden');
                    }
                    renderPlots();
                    renderBiomarkers();
                } catch (err) {
                    console.error("Upload error:", err);
                    alertBanner.className = "alert-strip amber";
                    alertBadge.textContent = "PARSE ERROR";
                    alertTitle.textContent = "File Import Failed";
                    alertDesc.textContent = err.message;
                    alertBanner.classList.remove('hidden');
                } finally {
                    btnText.textContent = "Run AI Diagnostic";
                    analyzeBtn.disabled = false;
                }
            });

            downloadJsonBtn.addEventListener('click', () => {
                if (!currentPayload) return;
                const blob = new Blob([JSON.stringify(currentPayload, null, 2)], { type: 'application/json' });
                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = `clinical_payload_${Date.now()}.json`;
                a.click();
                URL.revokeObjectURL(a.href);
            });

            (async () => {
                try {
                    const res = await fetch('/nmr-demo.json');
                    DEMO = await res.json();
                    loadActiveSample();
                } catch (e) {
                    console.error("Failed to load nmr-demo.json:", e);
                    alertBanner.className = "alert-strip";
                    alertBanner.style.background = "rgba(239,68,68,0.08)";
                    alertBanner.style.borderColor = "rgba(239,68,68,0.25)";
                    alertBadge.textContent = "DATA ERROR";
                    alertTitle.textContent = "Could not load demo dataset";
                    alertDesc.textContent = "nmr-demo.json is missing from /public. Re-generate the static data file.";
                    alertBanner.classList.remove('hidden');
                }
            })();
        });
    </script>
</body>
</html>
